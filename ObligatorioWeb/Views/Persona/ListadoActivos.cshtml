@{
}
@using Logica
@model List<Activo>


<h1>Listado de activos</h1>

<div class="activos-page">
    <form method="get" class="activos-form">
        <table class="activos-table">
            <thead>
                <tr>
                    <th>Nombre</th>
                    <th>Tipo de Activo</th>
                    <th>Criticidad</th>
                    <th>Backup</th>
                </tr>
            </thead>
            <tbody>
                
                @foreach (Activo a in Model)
                {
                    @if(a != null){
                    <tr>
                        <td>@a.Name</td>
                        <td>@a.Tipo</td>
                        <td>@a.Criticidad</td>
                        <td>@a.Backup</td>
                    </tr>
                    }
                    else
                {
                    <tr>
                            <td colspan="4">@ViewBag.Error</td>
                    </tr>
                }
                }
            </tbody>
        </table>
    </form>
</div>

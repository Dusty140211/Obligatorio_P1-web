@{
}
@using Logica
@using Obligatorio_P1
@model List<Incidente>




<div class="activos-page">
    <table class="activos-table">
    </hr>
    <h2>DATOS DE LA CUENTA</h2>
    <tr>
        <th>Id</th>
        <th>Fecha</th>
        <th>Estado</th>
        <th>Codigo de activo</th>
        <th>Severidad</th>
        
    </tr>
    @foreach (Incidente inc in Model)
    {
        <tr>
            <td>@inc.ID</td>
            <td>@inc.FechaReportado</td>
            <td>@inc.Estado</td>
            <td>@inc.ActivoAfectado.id</td>
            <td>@inc.Severidad()</td>
        
        </tr>
    }
</table>
</div>
@ViewBag.Error